# === Compact piloting environment (copy to .env) ===

# Service ports
NDVI_PORT=8081
WEATHER_PORT=8090

# Logging
RUST_LOG=info

# Auth (set real values in secure environments)
AUTH_DISABLED=true
AUTH_BYPASS_PATHS=/healthz,/metrics
JWT_SIGNING_KEY=replace_me
JWT_ISSUER=
JWT_AUDIENCE=
DJANGO_API_KEY_PEPPER=replace_me

# Throttling
THROTTLE_ENABLED=true
THROTTLE_ANON_RATE=100/min
THROTTLE_USER_RATE=1000/min
API_KEY_THROTTLE_RATE=10/min

# Postgres (NDVI)
POSTGRES_USER=ndvi
POSTGRES_PASSWORD=ndvi
POSTGRES_DB=ndvi
POSTGRES_PORT=5433

# MySQL (Weather / API key validation)
MYSQL_ROOT_PASSWORD=weather_root
MYSQL_DATABASE=weather
MYSQL_USER=weather
MYSQL_PASSWORD=weather
MYSQL_PORT=3307

# Weather provider defaults
WEATHER_PROVIDER_DEFAULT=open_meteo
WEATHER_DEFAULT_TZ=Africa/Nairobi
WEATHER_MAX_RANGE_DAYS=366
WEATHER_NASA_POWER_COMMUNITY=AG
NASA_POWER_DAILY_LAG_DAYS=2
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_TIMEOUT_S=10
OPEN_METEO_MAX_RETRIES=2
OPEN_METEO_BACKOFF_S=0.5
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point
NASA_POWER_TIMEOUT_S=10
